# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon Postgres for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:pass@your-neon-host/dbname?sslmode=require

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenRouteService (optional, used only for geocoding fallback)
ORS_API_KEY=

# Mapbox (primary routing provider - get a free key at https://account.mapbox.com/)
MAPBOX_ACCESS_TOKEN=
